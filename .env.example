# ═══════════════════════════════════════════════════════
# SARAS Robot Control — Environment Variables
# ═══════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# NEVER commit your .env file — it contains API keys
# ═══════════════════════════════════════════════════════

# ── Sarvam AI (LLM Chatbot) ────────────────────────────
# Get your key from: https://dashboard.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Flask Secret Key ───────────────────────────────────
# Any random string works — change this to something unique
SECRET_KEY=your_secret_key_here

# ── Arduino Serial Port ────────────────────────────────
# Windows : COM3, COM4, etc. (check Device Manager)
# Linux   : /dev/ttyUSB0 or /dev/ttyACM0
SERIAL_PORT=COM3
BAUD_RATE=9600

# ── Simulation Mode ────────────────────────────────────
# True  = no Arduino needed (testing on PC)
# False = real Arduino connected
SERIAL_MOCK=True
