# ═══════════════════════════════════════════════════════
# SARAS Robot Control — Environment Variables
# ═══════════════════════════════════════════════════════
# Place this file in: robot_control/.env
# NEVER share this file publicly — it contains API keys
# ═══════════════════════════════════════════════════════

# ── Sarvam AI (LLM Chatbot) ────────────────────────────
# IMPORTANT: Your old key was exposed publicly.
# Regenerate a new one at: https://dashboard.sarvam.ai/
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flask Secret Key ───────────────────────────────────
SECRET_KEY=saras_robot_secret_2024

# ── Arduino Serial Port ────────────────────────────────
# Windows : COM3, COM4, etc. (check Device Manager)
# Linux   : /dev/ttyUSB0 or /dev/ttyACM0
SERIAL_PORT=COM3
BAUD_RATE=9600

# ── Simulation Mode ────────────────────────────────────
# True  = no Arduino needed (testing on PC)
# False = real Arduino connected
SERIAL_MOCK=True
